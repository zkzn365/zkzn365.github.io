---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "中科智农（云南）科技有限责任公司 - AI智能体·小程序·跨境电商定制开发",
  description = "中科智农是一家专注于企业数字化定制开发的技术公司，提供AI智能体开发、小程序开发、跨境电商平台搭建等一站式解决方案"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI智能体开发,小程序开发,跨境电商,企业官网,系统定制开发,云南昆明" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-dark text-slate-300 font-sans antialiased">
    <!-- 导航栏 -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-dark/80 backdrop-blur-md border-b border-slate-800">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold bg-gradient-to-r from-primary to-blue-400 bg-clip-text text-transparent">
          中科智农
        </a>
        <div class="hidden md:flex gap-8">
          <a href="/" class="text-slate-300 hover:text-primary transition">首页</a>
          <a href="/services" class="text-slate-300 hover:text-primary transition">服务项目</a>
          <a href="/cases" class="text-slate-300 hover:text-primary transition">成功案例</a>
          <a href="/about" class="text-slate-300 hover:text-primary transition">关于我们</a>
          <a href="/contact" class="text-slate-300 hover:text-primary transition">联系我们</a>
        </div>
        <a href="/contact" class="hidden md:inline-block bg-primary text-white px-6 py-2 rounded-lg hover:bg-primary/90 transition">
          立即咨询
        </a>
      </nav>
    </header>

    <!-- 主内容 -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="bg-slate-950 py-12 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">中科智农（云南）科技有限责任公司</h3>
            <p class="text-slate-400">专注企业数字化定制开发</p>
          </div>
          <div>
            <h4 class="font-semibold mb-3 text-white">服务项目</h4>
            <ul class="space-y-2 text-slate-400">
              <li>AI智能体开发</li>
              <li>小程序开发</li>
              <li>跨境电商平台</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-3 text-white">联系我们</h4>
            <p class="text-slate-400">电话：0086-13997366845</p>
            <p class="text-slate-400">邮箱：wangleihd@gmail.com</p>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-slate-800 text-center text-slate-500">
          © 2026 中科智农（云南）科技有限责任公司 版权所有
        </div>
      </div>
    </footer>
  </body>
</html>