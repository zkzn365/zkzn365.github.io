---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="服务项目 - 中科智农">
  <section class="py-20 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center text-white">服务项目</h1>
      
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="p-8 bg-slate-800/50 border border-slate-700 rounded-2xl">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-4xl">🤖</span>
            <h2 class="text-2xl font-bold text-white">AI智能体开发</h2>
          </div>
          <ul class="list-disc pl-5 space-y-2 text-slate-400">
            <li>企业智能问答机器人</li>
            <li>自动化办公AI助手</li>
            <li>大模型微调与私有化部署</li>
            <li>AI数据分析与决策系统</li>
          </ul>
        </div>

        <div class="p-8 bg-slate-800/50 border border-slate-700 rounded-2xl">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-4xl">📱</span>
            <h2 class="text-2xl font-bold text-white">小程序开发</h2>
          </div>
          <ul class="list-disc pl-5 space-y-2 text-slate-400">
            <li>微信小程序定制开发</li>
            <li>商城/团购/预约/表单系统</li>
            <li>多端合一小程序开发</li>
            <li>小程序维护与升级服务</li>
          </ul>
        </div>

        <div class="p-8 bg-slate-800/50 border border-slate-700 rounded-2xl">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-4xl">🌍</span>
            <h2 class="text-2xl font-bold text-white">跨境电商平台</h2>
          </div>
          <ul class="list-disc pl-5 space-y-2 text-slate-400">
            <li>多语言外贸独立站</li>
            <li>国际支付/物流集成</li>
            <li>库存管理与订单系统</li>
            <li>SEO优化与海外推广</li>
          </ul>
        </div>

        <div class="p-8 bg-slate-800/50 border border-slate-700 rounded-2xl">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-4xl">💻</span>
            <h2 class="text-2xl font-bold text-white">全栈定制开发</h2>
          </div>
          <ul class="list-disc pl-5 space-y-2 text-slate-400">
            <li>企业管理系统开发</li>
            <li>CRM/ERP系统定制</li>
            <li>API接口开发与集成</li>
            <li>技术咨询与架构设计</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>