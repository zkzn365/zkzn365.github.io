---
import Layout from '../layouts/Layout.astro';
---

<Layout title="成功案例 - 中科智农">
  <section class="py-20 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center text-white">成功案例</h1>
      <p class="text-center text-slate-400 mb-12">已服务200+企业客户，覆盖多个行业领域</p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl overflow-hidden hover:border-primary/50 transition">
          <div class="h-48 bg-gradient-to-br from-primary/20 to-primary/5"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-white">某集团AI客服系统</h3>
            <p class="text-slate-400 text-sm">AI智能体 · 企业服务</p>
          </div>
        </div>
        
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl overflow-hidden hover:border-primary/50 transition">
          <div class="h-48 bg-gradient-to-br from-green-500/20 to-green-500/5"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-white">跨境电商独立站</h3>
            <p class="text-slate-400 text-sm">跨境电商 · 外贸平台</p>
          </div>
        </div>
        
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl overflow-hidden hover:border-primary/50 transition">
          <div class="h-48 bg-gradient-to-br from-purple-500/20 to-purple-500/5"></div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2 text-white">某品牌小程序商城</h3>
            <p class="text-slate-400 text-sm">小程序开发 · 电商商城</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>